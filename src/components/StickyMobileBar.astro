---
import { CONTACT, BOOKING } from '../config';
---

<div class="md:hidden fixed inset-x-0 bottom-0 z-30 border-t border-ink-100 bg-paper-elevated/95 backdrop-blur shadow-[0_-8px_24px_-12px_rgba(0,0,0,0.12)]">
  <div class="grid grid-cols-2">
    <a
      href={`tel:${CONTACT.phoneRaw}`}
      class="flex items-center justify-center gap-2 border-r border-ink-100 py-3 text-[0.9375rem] font-semibold text-brand-blue-dark"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.71 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.58 2.81.71A2 2 0 0 1 22 16.92Z" />
      </svg>
      Call
    </a>
    <a
      href={BOOKING.general}
      class="flex items-center justify-center gap-2 py-3 text-[0.9375rem] font-semibold text-white bg-brand-red"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
        <line x1="16" y1="2" x2="16" y2="6" />
        <line x1="8" y1="2" x2="8" y2="6" />
        <line x1="3" y1="10" x2="21" y2="10" />
      </svg>
      Book Visit
    </a>
  </div>
</div>

<!-- Add padding to body on mobile so sticky bar doesn't cover content -->
<style>
  @media (max-width: 768px) {
    :global(body) {
      padding-bottom: 56px;
    }
  }
</style>
