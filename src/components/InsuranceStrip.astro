---
import { INSURANCE } from '../config';
---

<div class="rounded-xl bg-paper-tinted p-8 text-center">
  <p class="eyebrow">Insurance Accepted</p>
  <h3 class="mt-2 font-display text-h3 text-ink-900">Most major plans welcome</h3>
  <p class="mx-auto mt-2 max-w-2xl text-meta text-ink-500">
    We accept most major insurance plans. Verify your coverage by calling our office.
  </p>
  <ul class="mt-6 flex flex-wrap items-center justify-center gap-2">
    {
      INSURANCE.map((name) => (
        <li class="rounded-md border border-ink-100 bg-paper-elevated px-3 py-1.5 text-meta font-medium text-ink-700">
          {name}
        </li>
      ))
    }
  </ul>
</div>
