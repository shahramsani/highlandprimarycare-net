---
import Icon from './Icon.astro';

interface Props {
  faqs: Array<{ q: string; a: string }>;
}
const { faqs } = Astro.props;
---

<div class="divide-y divide-ink-100 rounded-xl border border-ink-100 bg-paper-elevated">
  {
    faqs.map((faq) => (
      <details class="group">
        <summary class="flex cursor-pointer list-none items-start justify-between gap-4 p-6 [&::-webkit-details-marker]:hidden">
          <span class="font-display text-h4 font-semibold text-ink-900">{faq.q}</span>
          <span class="mt-0.5 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-blue-soft text-brand-blue-dark transition-transform duration-200 group-open:rotate-45">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
          </span>
        </summary>
        <div class="px-6 pb-6 text-body text-ink-500">{faq.a}</div>
      </details>
    ))
  }
</div>
