---
/**
 * Reveal — wraps content so it fades-up when scrolled into view.
 * The IntersectionObserver lives in BaseLayout.astro (one observer for the whole page).
 *
 * Usage:
 *   <Reveal>...content...</Reveal>
 *   <Reveal delay={200}>...</Reveal>
 *   <Reveal as="section" class="extra-classes">...</Reveal>
 */

interface Props {
  as?: string;
  delay?: 0 | 100 | 200 | 300 | 400;
  class?: string;
}

const { as: Tag = 'div', delay = 0, class: classProp = '' } = Astro.props;
const delayClass = delay ? `reveal-delay-${delay}` : '';
---

<Tag class:list={['reveal', delayClass, classProp]}>
  <slot />
</Tag>
