---
import Icon from './Icon.astro';

interface Props {
  title: string;
  short: string;
  href: string;
  icon: string;
  featured?: boolean;
  /** Optional outcome badge ("avg. 18 lbs in 12 wks") */
  outcome?: string;
}
const { title, short, href, icon, featured = false, outcome } = Astro.props;

const iconMap: Record<string, string> = {
  HeartPulse: 'heart-pulse',
  Activity: 'activity',
  Bandage: 'bandage',
  Brain: 'brain',
  Scale: 'scale',
  Accessibility: 'accessibility',
  User: 'user',
  Apple: 'apple',
  Route: 'route',
  Zap: 'zap',
};
const iconName = iconMap[icon] ?? 'stethoscope';
---

<a
  href={href}
  class:list={[
    'group relative flex h-full flex-col overflow-hidden rounded-xl p-6 md:p-7',
    'transition-[transform,box-shadow,border-color] duration-300',
    featured
      ? [
          'border border-brand-red/20',
          'bg-[radial-gradient(140%_100%_at_0%_0%,rgba(254,229,234,0.7)_0%,#FFFFFF_55%)]',
          'hover:-translate-y-1',
          'hover:border-brand-red/40',
          'hover:shadow-[0_24px_48px_-20px_rgba(224,0,48,0.22)]',
        ]
      : [
          'border border-ink-100 bg-paper-elevated',
          'hover:-translate-y-1',
          'hover:border-brand-blue/30',
          'hover:shadow-[0_18px_40px_-16px_rgba(10,15,26,0.15)]',
        ],
  ]}
>
  {
    featured && (
      <span class="absolute right-4 top-4 inline-flex items-center gap-1 rounded-full bg-brand-red px-2.5 py-0.5 text-[0.6875rem] font-bold uppercase tracking-[0.08em] text-white">
        Most requested
      </span>
    )
  }

  <div
    class:list={[
      'inline-flex h-12 w-12 items-center justify-center rounded-xl transition-transform duration-300',
      'group-hover:scale-[1.08]',
      featured ? 'bg-brand-red text-white shadow-[0_8px_20px_-8px_rgba(224,0,48,0.45)]' : 'bg-brand-blue-soft text-brand-blue-dark',
    ]}
  >
    <Icon name={iconName as any} size={24} />
  </div>

  <h3
    class:list={[
      'mt-5 font-display text-h4 font-semibold leading-tight',
      featured ? 'text-ink-900' : 'text-ink-900',
    ]}
  >
    {title}
  </h3>

  <p class="mt-2 flex-1 text-body text-ink-500">{short}</p>

  {
    outcome && (
      <p class="mt-3 inline-flex items-center gap-1.5 text-meta font-semibold text-brand-blue-dark">
        <Icon name="trending-up" size={14} />
        {outcome}
      </p>
    )
  }

  <span
    class:list={[
      'mt-auto pt-5 inline-flex items-center gap-1.5 text-meta font-semibold',
      featured ? 'text-brand-red-dark' : 'text-brand-blue-dark',
    ]}
  >
    Learn more
    <Icon name="arrow-right" size={16} class="transition-transform duration-200 group-hover:translate-x-1" />
  </span>
</a>
