---
import { SITE, CONTACT, NAV } from '../config';
import Icon from './Icon.astro';
const year = new Date().getFullYear();
---

<footer class="mt-20 bg-surface-dark text-white">
  <div class="container-x py-16">
    <div class="grid gap-12 md:grid-cols-12">
      <!-- Brand block -->
      <div class="md:col-span-4">
        <a href="/" class="inline-block" aria-label="Highland Primary Care home">
          <img
            src="/images/logo-mono-light.svg"
            alt="Highland Primary Care"
            width="1080"
            height="444"
            class="block h-14 w-auto md:h-16"
          />
        </a>
        <p class="mt-5 max-w-sm text-meta text-ink-300">
          {SITE.tagline}. Comprehensive primary care for the whole family in Sherman, TX.
        </p>
        <div class="mt-6 flex gap-3">
          <a href={CONTACT.socials.facebook} aria-label="Facebook" class="rounded-md border border-ink-700 p-2 transition-colors hover:bg-brand-red hover:border-brand-red">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.563 9.876v-6.988H7.898V12h2.539V9.797c0-2.506 1.492-3.89 3.776-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.772-1.63 1.563V12h2.773l-.443 2.888h-2.33v6.988A10.002 10.002 0 0 0 22 12Z"/></svg>
          </a>
          <a href={CONTACT.socials.instagram} aria-label="Instagram" class="rounded-md border border-ink-700 p-2 transition-colors hover:bg-brand-red hover:border-brand-red">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href={CONTACT.socials.youtube} aria-label="YouTube" class="rounded-md border border-ink-700 p-2 transition-colors hover:bg-brand-red hover:border-brand-red">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.5a3 3 0 0 0-2.1-2.1C19.5 4 12 4 12 4s-7.5 0-9.4.4A3 3 0 0 0 .5 6.5C.1 8.4.1 12 .1 12s0 3.6.4 5.5a3 3 0 0 0 2.1 2.1C4.5 20 12 20 12 20s7.5 0 9.4-.4a3 3 0 0 0 2.1-2.1c.4-1.9.4-5.5.4-5.5s0-3.6-.4-5.5ZM9.7 15.5v-7L16 12l-6.3 3.5Z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div class="md:col-span-2">
        <h3 class="font-display text-h4 text-white">Visit</h3>
        <ul class="mt-4 space-y-2 text-meta">
          {
            NAV.map((n) => (
              <li>
                <a href={n.href} class="text-ink-300 transition-colors hover:text-white">
                  {n.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Services -->
      <div class="md:col-span-3">
        <h3 class="font-display text-h4 text-white">Services</h3>
        <ul class="mt-4 space-y-2 text-meta">
          <li><a href="/medical-weight-loss/" class="text-ink-300 hover:text-white">Medical Weight Loss</a></li>
          <li><a href="/testosterone-replacement-therapy/" class="text-ink-300 hover:text-white">Testosterone Replacement</a></li>
          <li><a href="/preventive-services/" class="text-ink-300 hover:text-white">Preventive Care</a></li>
          <li><a href="/management-of-chronic-conditions/" class="text-ink-300 hover:text-white">Chronic Disease</a></li>
          <li><a href="/mental-health-services/" class="text-ink-300 hover:text-white">Mental Health</a></li>
          <li><a href="/elderly-care/" class="text-ink-300 hover:text-white">Elderly Care</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-3">
        <h3 class="font-display text-h4 text-white">Contact</h3>
        <address class="mt-4 flex items-start gap-2 not-italic text-meta text-ink-300">
          <Icon name="map-pin" size={16} class="mt-0.5 shrink-0" />
          <span>
            {CONTACT.address.street}<br />
            {CONTACT.address.city}, {CONTACT.address.state} {CONTACT.address.zip}
          </span>
        </address>
        <p class="mt-3 flex items-center gap-2 text-meta text-ink-300">
          <Icon name="phone" size={16} class="shrink-0" />
          <a href={`tel:${CONTACT.phoneRaw}`} class="text-ink-300 transition-colors hover:text-white">{CONTACT.phone}</a>
        </p>
        <p class="mt-1 flex items-center gap-2 text-meta text-ink-300">
          <Icon name="mail" size={16} class="shrink-0" />
          <a href={`mailto:${CONTACT.email}`} class="text-ink-300 transition-colors hover:text-white">{CONTACT.email}</a>
        </p>
        <div class="mt-4 flex items-start gap-2 text-meta text-ink-300">
          <Icon name="clock" size={16} class="mt-0.5 shrink-0" />
          <div>
            <span class="block font-semibold text-white">Office Hours</span>
            Monday – Friday: 8:00 AM – 5:00 PM<br />
            Saturday – Sunday: Closed
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-ink-700 pt-8 text-meta md:flex-row md:items-center">
      <p class="text-ink-300">© {year} {SITE.name}. All rights reserved.</p>
      <ul class="flex gap-6">
        <li><a href="/privacy-policy/" class="text-ink-300 transition-colors hover:text-white">Privacy Policy</a></li>
        <li><a href="/terms-and-conditions/" class="text-ink-300 transition-colors hover:text-white">Terms and Conditions</a></li>
      </ul>
    </div>
  </div>
</footer>
