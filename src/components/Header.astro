---
import { CONTACT, NAV, BOOKING } from '../config';
import Icon from './Icon.astro';
---

<header
  id="site-header"
  class="sticky top-0 z-40 bg-paper transition-[box-shadow] duration-200 [&.is-scrolled]:shadow-[0_1px_0_rgba(10,15,26,0.08),0_8px_32px_-20px_rgba(10,15,26,0.18)]"
>
  <!-- Announcement bar -->
  <div class="bg-surface-dark text-white">
    <div class="container-x flex h-9 items-center justify-between text-meta">
      <span class="hidden md:block">
        <span class="mr-2 inline-block h-1.5 w-1.5 rounded-full bg-emerald-400 align-middle animate-pulse"></span>
        Now accepting new patients · Same-day appointments available
      </span>
      <span class="md:hidden inline-flex items-center gap-2">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        Accepting new patients
      </span>
      <a href={`tel:${CONTACT.phoneRaw}`} class="inline-flex items-center gap-1.5 font-semibold text-white hover:text-brand-red-soft">
        <Icon name="phone" size={14} />
        {CONTACT.phone}
      </a>
    </div>
  </div>

  <!-- Main nav -->
  <div class="container-x flex h-24 items-center justify-between md:h-28">
    <a href="/" class="group inline-flex items-center" aria-label="Highland Primary Care home">
      <img
        src="/images/logo.svg"
        alt="Highland Primary Care"
        class="block h-16 w-auto transition-transform duration-300 ease-out group-hover:scale-[1.02] md:h-20"
        width="1080"
        height="444"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-9 lg:flex" aria-label="Primary">
      {
        NAV.map((item) => (
          <div class="group/nav relative">
            <a
              href={item.href}
              class="inline-flex items-center gap-1 text-[0.9375rem] font-medium text-ink-700 transition-colors hover:text-brand-red"
            >
              <span class="link-underline">{item.label}</span>
              {item.children && (
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover/nav:rotate-180">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              )}
            </a>
            {item.children && (
              <div class="invisible absolute left-1/2 top-full z-50 mt-3 w-[28rem] -translate-x-1/2 translate-y-1 rounded-2xl border border-ink-100/80 bg-paper-elevated/95 p-3 opacity-0 shadow-[0_28px_64px_-24px_rgba(10,15,26,0.28)] backdrop-blur-md transition-all duration-200 group-hover/nav:visible group-hover/nav:translate-y-0 group-hover/nav:opacity-100">
                <ul class="grid grid-cols-2 gap-1">
                  {item.children.map((child) => (
                    <li class={child.featured ? 'col-span-2' : ''}>
                      <a
                        href={child.href}
                        class:list={[
                          'flex items-start gap-3 rounded-xl px-3 py-3 text-[0.9375rem] transition-colors',
                          child.featured
                            ? 'bg-[radial-gradient(120%_100%_at_0%_0%,rgba(254,229,234,0.7),transparent_60%)] font-semibold text-brand-red-dark hover:bg-brand-red hover:text-white'
                            : 'text-ink-700 hover:bg-paper-tinted hover:text-brand-blue-dark',
                        ]}
                      >
                        {child.featured && (
                          <span class="mt-0.5 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-brand-red text-white">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                          </span>
                        )}
                        <span>{child.label}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a href={`tel:${CONTACT.phoneRaw}`} class="hidden text-[0.9375rem] font-semibold text-ink-700 hover:text-brand-red md:inline">
        {CONTACT.phone}
      </a>
      <a href={BOOKING.bookNow} class="btn-primary hidden md:inline-flex">
        <Icon name="calendar" size={16} />
        Book Visit
      </a>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-nav-toggle"
        type="button"
        class="lg:hidden inline-flex items-center justify-center rounded-md p-2 text-ink-900"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav drawer -->
  <div
    id="mobile-nav"
    class="hidden lg:hidden border-t border-ink-100 bg-paper-elevated"
  >
    <nav class="container-x py-4" aria-label="Mobile">
      <ul class="space-y-1">
        {
          NAV.map((item) => (
            <li>
              <a href={item.href} class="block rounded-md px-3 py-3 text-base font-medium text-ink-900 hover:bg-paper-tinted">
                {item.label}
              </a>
              {item.children && (
                <ul class="ml-3 mt-1 space-y-1 border-l-2 border-ink-100 pl-3">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class:list={[
                          'block rounded-md px-3 py-2 text-[0.9375rem]',
                          child.featured ? 'font-semibold text-brand-red-dark' : 'text-ink-700 hover:bg-paper-tinted',
                        ]}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
      <a href={BOOKING.bookNow} class="btn-primary mt-4 w-full">
        <Icon name="calendar" size={16} />
        Book Visit
      </a>
    </nav>
  </div>
</header>

<script>
  // Re-query DOM elements on every page load so View Transitions don't break listeners.
  let scrollController: AbortController | null = null;

  function initNav() {
    // Mobile drawer — abort previous scroll listener before re-registering.
    scrollController?.abort();
    scrollController = new AbortController();

    const toggle = document.getElementById('mobile-nav-toggle') as HTMLButtonElement | null;
    const nav = document.getElementById('mobile-nav');

    if (toggle && nav) {
      // Clone the toggle to drop any stale event listeners from previous loads.
      const fresh = toggle.cloneNode(true) as HTMLButtonElement;
      toggle.replaceWith(fresh);
      fresh.addEventListener('click', () => {
        const expanded = fresh.getAttribute('aria-expanded') === 'true';
        fresh.setAttribute('aria-expanded', String(!expanded));
        nav.classList.toggle('hidden');
      });
    }

    // Header glass on scroll
    const header = document.getElementById('site-header');
    const onScroll = () => {
      if (!header) return;
      if (window.scrollY > 8) header.classList.add('is-scrolled');
      else header.classList.remove('is-scrolled');
    };
    onScroll();
    window.addEventListener('scroll', onScroll, {
      passive: true,
      signal: scrollController.signal,
    });
  }

  // Run immediately if DOM is ready (initial hard load), then again on every
  // Astro View Transitions page swap.
  if (document.readyState !== 'loading') {
    initNav();
  }
  document.addEventListener('astro:page-load', initNav);
</script>
