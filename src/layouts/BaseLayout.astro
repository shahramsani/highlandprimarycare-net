---
import { SEO } from 'astro-seo';
import '../styles/global.css';
import { SITE, CONTACT } from '../config';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyMobileBar from '../components/StickyMobileBar.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  schemaJson?: object | object[];
}

const {
  title,
  description = SITE.description,
  canonical = SITE.url + Astro.url.pathname,
  ogImage = SITE.url + SITE.ogImage,
  noindex = false,
  schemaJson,
} = Astro.props;

const fullTitle = title.includes(SITE.name) ? title : `${title} | ${SITE.name}`;
const schemas = Array.isArray(schemaJson) ? schemaJson : schemaJson ? [schemaJson] : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#E00030" />

    <SEO
      title={fullTitle}
      description={description}
      canonical={canonical}
      noindex={noindex}
      openGraph={{
        basic: {
          title: fullTitle,
          type: 'website',
          image: ogImage,
          url: canonical,
        },
        optional: {
          siteName: SITE.name,
          locale: SITE.locale,
          description,
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title: fullTitle,
        description,
        image: ogImage,
      }}
    />

    {
      schemas.map((s) => (
        <script type="application/ld+json" set:html={JSON.stringify(s)} />
      ))
    }

    <!-- Preconnect for performance -->
    <link rel="dns-prefetch" href="https://app.highlandprimarycare.cc" />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-brand-blue focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />
    <StickyMobileBar />

    <!-- Facebook Pixel (preserved from existing site) -->
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        src="https://www.facebook.com/tr?id=812623817653317&ev=PageView&noscript=1"
        alt=""
      />
    </noscript>
  </body>
</html>
