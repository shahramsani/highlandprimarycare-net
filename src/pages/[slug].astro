const standardProviderFaqs = (providerName: string) => [
  {
    q: `Is ${providerName.split(',')[0]} accepting new patients?`,
    a: `Yes. ${providerName.split(',')[0]} is currently accepting new patients at Highland Primary Care in Sherman, TX. Call 903-871-5671 to schedule.`,
