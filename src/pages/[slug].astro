            <ul class="mt-10 flex flex-wrap items-center gap-x-7 gap-y-3 text-meta text-ink-700 animate-fade-up animation-delay-500">
              <li class="inline-flex items-center gap-2">
                <span class="relative inline-flex h-2.5 w-2.5">
                  <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-60"></span>
                  <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
                </span>
                Accepting new patients
              </li>
              <li class="inline-flex items-center gap-2">
                <Icon name="shield-check" size={16} class="text-brand-blue-dark" />
                Most insurance welcome
              </li>
              <li class="inline-flex items-center gap-2">
                <Icon name="map-pin" size={16} class="text-brand-blue-dark" />
                Sherman, TX
              </li>
            </ul>
          </div>
        </div>
      </section>

      {/* ====================================================
           INTRO — drop cap lead paragraph
           ==================================================== */}
      {props.content.intro.length > 0 && (
        <section class="section">
          <div class="container-x">
            <Reveal>
              <div class="prose-medical mx-auto">
                <p class="text-lead text-ink-700">
                  <span class="float-left mr-3 mt-1 font-display text-display font-semibold text-brand-red leading-[0.85]">
                    {serviceCtx.firstParaFirstLetter}
                  </span>
                  {serviceCtx.firstParaRest}
                </p>
                {serviceCtx.remainingIntro.map((p) => (
                  <p>{p}</p>
                ))}
              </div>
            </Reveal>
          </div>
        </section>
      )}

      {/* ====================================================
           CAPABILITIES — what we offer
           ==================================================== */}
      <section class="section section-tinted">
        <div class="container-x">
          <Reveal class="section-head mx-auto text-center">
            <span class="eyebrow-dot">What We Offer</span>
            <h2 class="editorial mt-3 text-h1 balance">
              {serviceCtx.titleSplit.lead}{' '}
              <em>{serviceCtx.titleSplit.accent}</em>
            </h2>
            <p class="text-lead text-ink-500 pretty">
              Everything included with your care — grounded in current guidelines and personal follow-through.
            </p>
          </Reveal>

          <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {props.content.capabilities.map((cap, i) => (
              <Reveal delay={((i % 3) * 100) as 0 | 100 | 200}>
                <div class="card-premium halo h-full">
                  <span class="icon-tile">
                    <Icon name={cap.icon as any} size={22} />
                  </span>
                  <h3 class="mt-5 font-display text-h4 font-semibold text-ink-900">{cap.title}</h3>
                  <p class="mt-2 text-body text-ink-500">{cap.body}</p>
                </div>
              </Reveal>
            ))}
          </div>
        </div>
      </section>

      {/* ====================================================
           EVIDENCE
           ==================================================== */}
      {props.content.evidence && (
        <section class="section">
          <div class="container-x">
            <Reveal>
              <div class="mx-auto max-w-3xl rounded-2xl border-l-4 border-brand-blue bg-brand-blue-soft p-8 md:p-10">
                <span class="eyebrow text-brand-blue-dark">Evidence-Based Care</span>
                <p class="mt-3 text-body text-ink-700">{props.content.evidence.lede}</p>
                <ul class="mt-5 space-y-2">
                  {props.content.evidence.links.map((link) => (
                    <li>
                      <a
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1.5 text-meta font-semibold text-brand-blue-dark hover:text-brand-blue wipe-underline"
                      >
                        {link.label}
                        <Icon name="arrow-up-right" size={14} />
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </Reveal>
          </div>
        </section>
      )}

      {/* ====================================================
           STATS / OUTCOMES STRIP (subset of services)
           ==================================================== */}
      {serviceCtx.stats && (
        <section class="section section-tinted">
          <div class="container-x">
            <Reveal class="section-head mx-auto text-center">
              <span class="eyebrow-dot">By the numbers</span>
              <h2 class="editorial mt-3 text-h1 balance">
                The kind of care that <em>compounds</em>.
              </h2>
            </Reveal>
            <div class="mt-14 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
              {serviceCtx.stats.map((s) => (
                <AnimatedStat
                  value={s.value}
                  suffix={s.suffix}
                  prefix={s.prefix}
                  label={s.label}
                  accent={s.accent}
                />
              ))}
            </div>
          </div>
        </section>
      )}

      {/* ====================================================
           FAQ
           ==================================================== */}
      <section class="section section-tinted">
        <div class="container-x">
          <Reveal>
            <SectionHeader eyebrow="FAQ" title="Frequently asked questions" align="center" />
          </Reveal>
          <div class="mx-auto mt-12 max-w-3xl">
            <Reveal>
              <FAQ faqs={props.content.faqs} />
            </Reveal>
          </div>
        </div>
      </section>

      {/* ====================================================
           BOOKING
           ==================================================== */}
      <section class="section bg-white">
        <div class="container-x">
          <Reveal>
            <SectionHeader eyebrow="Get Started" title="Schedule your visit" align="center" />
          </Reveal>
          <div class="mx-auto mt-12 max-w-[650px]">
            <Reveal>
              <BookingEmbed src={BOOKING.general} />
            </Reveal>
          </div>
        </div>
      </section>

      <CTABanner />
    </BaseLayout>
  )
}
