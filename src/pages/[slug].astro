    ed: splitProviderName(props.provider.slug, props.provider.name),
    extras: providerExtras[props.provider.slug],
    faqs: standardProviderFaqs(props.provider.name),
  };
}

let serviceCtx: {
  heroSplit: { lead: string; accent: string };
  titleSplit: { lead: string; accent: string };
  firstParaFirstLetter: string;
  firstParaRest: string;
  remainingIntro: string[];
  stats: ServiceStat[] | undefined;
} | null = null;

if (props.kind === 'service') {
  const intro = props.content.intro;
  const firstPara = intro[0] ?? '';
  serviceCtx = {
    heroSplit: splitHeroHeadline(props.content.hero),
    titleSplit: splitTitleAccent(props.content.title),
    firstParaFirstLetter: firstPara.charAt(0),
    firstParaRest: firstPara.slice(1),
    remainingIntro: intro.slice(1),
    stats: serviceStats[props.content.slug],
  };
}
