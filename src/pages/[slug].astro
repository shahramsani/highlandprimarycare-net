import { PROVIDERS, TESTIMONIALS, BOOKING, CONTACT } from '../config';
import { SERVICE_CONTENT } from '../content/services';
import {
  physicianSchema,
  faqSchema,
  medicalServiceSchema,
  breadcrumbSchema,
} from '../schema';

export function getStaticPaths() {
  const providerPaths = PROVIDERS.map((p) => ({
    params: { slug: p.slug },
    props: { kind: 'provider' as const, provider: p },
  }));
  const servicePaths = Object.values(SERVICE_CONTENT).map((s) => ({
    params: { slug: s.slug },
    props: { kind: 'service' as const, content: s },
  }));
  return [...providerPaths, ...servicePaths];
}

const props = Astro.props as
  | { kind: 'provider'; provider: (typeof PROVIDERS)[number] }
  | { kind: 'service'; content: (typeof SERVICE_CONTENT)[string] };

/* ------------------------------------------------------------------
   Provider helpers — split name for editorial italic accent on the
   surname (Sani / Keahey / Warke).
------------------------------------------------------------------- */
type EditorialName = { lead: string; accent: string; credentials: string };

function splitProviderName(slug: string, fullName: string): EditorialName {
  // Strip trailing credentials (anything after the first comma)
  const [namePart, ...credParts] = fullName.split(',');
  const credentials = credParts.join(',').trim();
  const accentMap: Record<string, string> = {
    'dr-shahram-sani': 'Sani',
    'diane-keahey': 'Keahey',
    'dr-amit-warke': 'Warke',
  };
  const accent = accentMap[slug] ?? namePart.trim().split(/\s+/).slice(-1)[0];
  const lead = namePart.trim().replace(new RegExp(`\\s*${accent}\\s*$`), '').trim();
  return { lead, accent, credentials };
}

