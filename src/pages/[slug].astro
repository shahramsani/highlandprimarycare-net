  },
  {
    q: 'Where is the practice located?',
    a: '300 N Highland Ave, Suite 455, Sherman, TX 75092.',
  },
];

/* Pre-compute branch-specific values (Astro can't run logic inside JSX safely). */
let providerCtx: {
  ed: EditorialName;
  extras: (typeof providerExtras)[string];
  faqs: ReturnType<typeof standardProviderFaqs>;
} | null = null;

