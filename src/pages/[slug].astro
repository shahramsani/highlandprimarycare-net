/* ------------------------------------------------------------------
   Service helper — split the hero headline so the last meaningful
   word can be wrapped in <em> for the editorial italic-red accent.
------------------------------------------------------------------- */
function splitHeroHeadline(hero: string): { lead: string; accent: string } {
  const tokens = hero.trim().split(/\s+/);
  if (tokens.length < 2) return { lead: '', accent: hero };

  // Strip trailing punctuation from the last token (but keep it for display)
  const lastIdx = tokens.length - 1;
  const lastRaw = tokens[lastIdx];

  // Prefer keyword-based emphasis where a meaningful verb/noun pair exists
  const emphasisKeywords = [
    'today',
    'today.',
    'wrong.',
    'conditions.',
    'care.',
    'men.',
    'well.',
    'surprises.',
    'covered.',
    'today?',
    'today!',
  ];
  const lower = lastRaw.toLowerCase();

  // Default — italicize the final word with any trailing punctuation kept
  if (emphasisKeywords.includes(lower) || tokens.length >= 2) {
    return {
      lead: tokens.slice(0, lastIdx).join(' '),
      accent: lastRaw,
    };
  }

  return { lead: tokens.slice(0, lastIdx).join(' '), accent: lastRaw };
}

function splitTitleAccent(title: string): { lead: string; accent: string } {
  const tokens = title.trim().split(/\s+/);
  if (tokens.length < 2) return { lead: '', accent: title };
  return {
    lead: tokens.slice(0, -1).join(' '),
    accent: tokens[tokens.length - 1],
  };
}

