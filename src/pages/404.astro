---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout title="Page Not Found — Highland Primary Care" noindex>
  <section class="section">
    <div class="container-x text-center">
      <p class="font-display text-display text-brand-red">404</p>
      <h1 class="mt-4 font-display text-h1 text-ink-900">We couldn't find that page.</h1>
      <p class="mx-auto mt-4 max-w-xl text-lead text-ink-500">
        The link may be broken, the page may have moved, or it may not exist. Here are some popular places to go next.
      </p>
      <ul class="mx-auto mt-10 grid max-w-2xl gap-3 sm:grid-cols-2">
        {
          [
            { href: '/', label: 'Home' },
            { href: '/our-services/', label: 'Services' },
            { href: '/about-us/', label: 'About Us' },
            { href: '/contact-us/', label: 'Contact' },
            { href: '/medical-weight-loss/', label: 'Medical Weight Loss' },
            { href: '/testosterone-replacement-therapy/', label: 'TRT' },
          ].map((l) => (
            <li>
              <a
                href={l.href}
                class="flex items-center justify-between rounded-lg border border-ink-100 bg-paper-elevated px-4 py-3 text-left transition-colors hover:border-brand-blue"
              >
                <span class="font-semibold text-ink-700">{l.label}</span>
                <Icon name="arrow-right" size={18} class="text-brand-blue-dark" />
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
