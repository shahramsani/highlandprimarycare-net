---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProviderCard from '../components/ProviderCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Testimonial from '../components/Testimonial.astro';
import CTABanner from '../components/CTABanner.astro';
import TrustStrip from '../components/TrustStrip.astro';
import InsuranceStrip from '../components/InsuranceStrip.astro';
import FAQ from '../components/FAQ.astro';
import BookingEmbed from '../components/BookingEmbed.astro';
import Icon from '../components/Icon.astro';
import { PROVIDERS, SERVICES, TESTIMONIALS, BOOKING, CONTACT } from '../config';
import { localBusinessSchema, faqSchema } from '../schema';

const homeFAQs = [
  {
    q: 'Are you accepting new patients?',
    a: 'Yes. Highland Primary Care is currently accepting new patients of all ages. Call (903) 871-5671 or book online to schedule your first visit.',
  },
  {
    q: 'What insurance do you accept?',
    a: 'We accept most major insurance plans including Medicare, Medicaid, Blue Cross Blue Shield, Aetna, Cigna, UnitedHealthcare, Humana, Tricare, and more. Call to verify your specific plan.',
  },
  {
    q: 'Do you offer same-day appointments?',
    a: 'Yes. Same-day appointments are often available for acute illnesses, infections, and urgent medical concerns. Call us first thing in the morning for the best chance of getting in.',
  },
  {
    q: 'Where are you located?',
    a: '300 N Highland Ave, Suite 455, Sherman, TX 75092. We serve Sherman, Denison, Pottsboro, Howe, Whitesboro, Van Alstyne, and surrounding Texoma communities.',
  },
  {
    q: 'What should I bring to my first visit?',
    a: 'Please bring your insurance card, photo ID, a list of current medications, and any prior medical records or imaging you have available.',
  },
];

const featuredServices = SERVICES.filter((s) => s.featured).concat(
  SERVICES.filter((s) => !s.featured).slice(0, 4)
);
---

<BaseLayout
  title="Primary Care Sherman TX | Highland Primary Care Clinic"
  description="Highland Primary Care in Sherman, TX offers preventive care, medical weight loss, TRT, and chronic disease management. Now accepting new patients."
  schemaJson={[localBusinessSchema(), faqSchema(homeFAQs)]}
>
  <!-- ====================================================
       HERO
       ==================================================== -->
  <section class="relative overflow-hidden bg-paper">
    <!-- Background accents -->
    <div class="pointer-events-none absolute -right-32 -top-32 h-[28rem] w-[28rem] rounded-full bg-brand-blue-soft/60 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-40 -left-20 h-[24rem] w-[24rem] rounded-full bg-brand-red-soft/50 blur-3xl"></div>

    <div class="container-x relative grid items-center gap-12 py-16 lg:grid-cols-[1.05fr_0.95fr] lg:py-22">
      <div class="animate-fade-up">
        <span class="eyebrow">Primary Care · Sherman, TX</span>
        <h1 class="mt-4 font-display text-display font-semibold text-ink-900 text-balance">
          Your wellness journey<br />
          <span class="italic text-brand-red">starts here.</span>
        </h1>
        <p class="mt-6 max-w-xl text-lead text-ink-500 text-pretty">
          Comprehensive, personalized primary care from board-certified physicians with 25+ years of combined experience — right here in Texoma.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href={BOOKING.general} class="btn-primary">
            <Icon name="calendar" size={18} />
            Schedule Your Visit
          </a>
          <a href={`tel:${CONTACT.phoneRaw}`} class="btn-secondary">
            <Icon name="phone" size={18} />
            {CONTACT.phone}
          </a>
        </div>

        <ul class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-meta text-ink-700">
          <li class="inline-flex items-center gap-2">
            <Icon name="check-circle" size={16} class="text-brand-blue-dark" />
            Accepting new patients
          </li>
          <li class="inline-flex items-center gap-2">
            <Icon name="check-circle" size={16} class="text-brand-blue-dark" />
            Medicare welcome
          </li>
          <li class="inline-flex items-center gap-2">
            <Icon name="check-circle" size={16} class="text-brand-blue-dark" />
            Same-day appointments
          </li>
        </ul>
      </div>

      <!-- Hero image -->
      <div class="relative animate-fade-up animation-delay-200">
        <div class="relative aspect-[4/5] overflow-hidden rounded-2xl shadow-soft-lg">
          <img
            src="/images/dr-sani.png"
            alt="Dr. Shahram N. Sani, MD — Board-certified Internal Medicine Physician at Highland Primary Care"
            width="900"
            height="1125"
            class="h-full w-full object-cover object-top"
            fetchpriority="high"
          />
        </div>
        <!-- Floating credential badge -->
        <div class="absolute -bottom-6 -left-6 hidden rounded-xl bg-paper-elevated p-5 shadow-soft-lg ring-1 ring-ink-100 md:block">
          <p class="text-eyebrow font-semibold uppercase tracking-wider text-brand-blue-dark">Medical Director</p>
          <p class="mt-1 font-display text-h4 text-ink-900">Dr. Shahram N. Sani, MD</p>
          <p class="text-meta text-ink-500">Board-Certified · 25+ yrs experience</p>
        </div>
      </div>
    </div>
  </section>

  <TrustStrip />

  <!-- ====================================================
       MEET OUR PROVIDERS
       ==================================================== -->
  <section class="section">
    <div class="container-x">
      <SectionHeader
        eyebrow="Our Team"
        title="Meet your care team"
        lede="Board-certified physicians and providers dedicated to your long-term health and well-being."
        align="center"
      />
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          PROVIDERS.map((p) => (
            <ProviderCard
              name={p.name}
              title={p.title}
              photo={p.photo}
              specialties={p.specialties}
              short={p.short}
              href={`/${p.slug}/`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ====================================================
       SERVICES
       ==================================================== -->
  <section class="section section-tinted">
    <div class="container-x">
      <SectionHeader
        eyebrow="Comprehensive Care"
        title="One place. All your health needs."
        lede="From routine check-ups to advanced medical weight loss and hormone optimization — we cover the full spectrum of primary care."
        align="center"
      />
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          featuredServices.map((s) => (
            <ServiceCard
              title={s.title}
              short={s.short}
              href={`/${s.slug}/`}
              icon={s.icon}
              featured={s.featured}
            />
          ))
        }
      </div>
      <div class="mt-10 text-center">
        <a href="/our-services/" class="btn-secondary">
          See All Services
          <Icon name="arrow-right" size={18} />
        </a>
      </div>
    </div>
  </section>

  <!-- ====================================================
       WHY HIGHLAND
       ==================================================== -->
  <section class="section">
    <div class="container-x">
      <div class="grid gap-12 lg:grid-cols-[1fr_1.2fr] lg:items-center">
        <div>
          <SectionHeader
            eyebrow="Why Highland"
            title="A real medical practice. Real relationships."
            lede="We're not a chain. We're not a mail-order clinic. We're a long-established Sherman practice that takes the time to know you."
          />
          <a href="/about-us/" class="mt-8 inline-flex items-center gap-2 font-semibold text-brand-blue-dark hover:text-brand-blue">
            Learn about our practice
            <Icon name="arrow-right" size={18} />
          </a>
        </div>
        <ul class="grid gap-4 sm:grid-cols-2">
          <li class="card">
            <Icon name="award" size={28} class="text-brand-red" />
            <h3 class="mt-4 font-display text-h4 text-ink-900">Board-Certified</h3>
            <p class="mt-2 text-meta text-ink-500">All providers board-certified in their specialty.</p>
          </li>
          <li class="card">
            <Icon name="users" size={28} class="text-brand-red" />
            <h3 class="mt-4 font-display text-h4 text-ink-900">Patient-Centered</h3>
            <p class="mt-2 text-meta text-ink-500">We listen first. We don't rush appointments.</p>
          </li>
          <li class="card">
            <Icon name="microscope" size={28} class="text-brand-red" />
            <h3 class="mt-4 font-display text-h4 text-ink-900">On-Site Labs</h3>
            <p class="mt-2 text-meta text-ink-500">Bloodwork and screenings done in-office for convenience.</p>
          </li>
          <li class="card">
            <Icon name="map-pin" size={28} class="text-brand-red" />
            <h3 class="mt-4 font-display text-h4 text-ink-900">Local to Sherman</h3>
            <p class="mt-2 text-meta text-ink-500">Long-established Texoma practice serving North Texas.</p>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ====================================================
       TESTIMONIALS
       ==================================================== -->
  <section class="section section-tinted">
    <div class="container-x">
      <SectionHeader
        eyebrow="Patient Voices"
        title="What our patients say"
        lede="Real experiences from Highland Primary Care patients in Sherman and the surrounding Texoma area."
        align="center"
      />
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {TESTIMONIALS.map((t) => <Testimonial {...t} />)}
      </div>
    </div>
  </section>

  <!-- ====================================================
       INSURANCE
       ==================================================== -->
  <section class="section">
    <div class="container-x">
      <InsuranceStrip />
    </div>
  </section>

  <!-- ====================================================
       FAQ
       ==================================================== -->
  <section class="section">
    <div class="container-x">
      <SectionHeader
        eyebrow="Common Questions"
        title="Frequently asked questions"
        align="center"
      />
      <div class="mx-auto mt-12 max-w-3xl">
        <FAQ faqs={homeFAQs} />
      </div>
    </div>
  </section>

  <!-- ====================================================
       BOOKING + CTA
       ==================================================== -->
  <section class="section bg-paper-tinted">
    <div class="container-x">
      <SectionHeader
        eyebrow="Get Started"
        title="Request an appointment"
        lede="Fill out the form below and our team will contact you shortly. Or call us directly."
        align="center"
      />
      <div class="mx-auto mt-12 max-w-3xl">
        <BookingEmbed src={BOOKING.general} />
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
