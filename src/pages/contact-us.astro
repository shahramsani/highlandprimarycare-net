---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import BookingEmbed from '../components/BookingEmbed.astro';
import CTABanner from '../components/CTABanner.astro';
import Icon from '../components/Icon.astro';
import Reveal from '../components/Reveal.astro';
import MagneticButton from '../components/MagneticButton.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import { CONTACT, BOOKING, SITE } from '../config';
import { localBusinessSchema, breadcrumbSchema } from '../schema';
---

<BaseLayout
  title="Contact Highland Primary Care | Sherman TX Clinic"
  description="Contact Highland Primary Care in Sherman, TX. Call (903) 871-5671 or book online. Located at 300 N Highland Ave, Suite 455. Open Mon–Fri, 8am–5pm."
  schemaJson={[
    localBusinessSchema(),
    breadcrumbSchema([
      { name: 'Home', url: `${SITE.url}/` },
      { name: 'Contact', url: `${SITE.url}/contact-us/` },
    ]),
  ]}
>
  <ScrollProgress />

  <!-- ====================================================
       HERO
       ==================================================== -->
  <section class="hero-frame relative isolate">
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <div class="absolute -top-32 -left-24 h-[28rem] w-[28rem] rounded-full bg-brand-blue/10 blur-3xl animate-drift"></div>
      <div class="absolute -bottom-40 right-[-6rem] h-[32rem] w-[32rem] rounded-full bg-brand-red/8 blur-3xl animate-drift" style="animation-delay: -8s"></div>
    </div>

    <div class="container-x relative py-16 lg:py-24">
      <div class="mx-auto max-w-3xl text-center">
        <span class="eyebrow-dot animate-fade-up">Visit Us</span>
        <h1 class="editorial mt-6 text-display text-ink-900 balance animate-fade-up animation-delay-100">
          We'd love to <em>hear from you</em>.
        </h1>
        <p class="mx-auto mt-7 max-w-2xl text-lead text-ink-500 pretty animate-fade-up animation-delay-300">
          Call to schedule, ask a question, or simply stop by. Highland Primary Care is open Monday through Friday, 8am–5pm, at <strong class="font-semibold text-ink-700">{CONTACT.address.full}</strong>.
        </p>
        <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row animate-fade-up animation-delay-400">
          <a href={`tel:${CONTACT.phoneRaw}`} class="btn-primary">
            <Icon name="phone" size={18} />
            {CONTACT.phone}
          </a>
          <MagneticButton href={BOOKING.bookNow} class="btn-secondary group">
            <Icon name="calendar" size={18} />
            Book Online
            <Icon name="arrow-right" size={16} class="transition-transform duration-200 group-hover:translate-x-0.5" />
          </MagneticButton>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================
       INFO CARDS — address / hours / phone+email
       ==================================================== -->
  <section class="section">
    <div class="container-x">
      <div class="grid gap-6 lg:grid-cols-2">
        <Reveal>
          <div class="card-premium halo h-full">
            <div class="flex items-start gap-4">
              <span class="icon-tile icon-tile-red shrink-0">
                <Icon name="map-pin" size={22} />
              </span>
              <div>
                <h2 class="font-display text-h3 font-semibold text-ink-900">Visit our office</h2>
                <address class="mt-3 not-italic text-body text-ink-700">
                  {CONTACT.address.street}<br />
                  {CONTACT.address.city}, {CONTACT.address.state} {CONTACT.address.zip}
                </address>
                <ul class="mt-5 space-y-2 text-meta text-ink-500">
                  <li class="inline-flex items-start gap-2">
                    <Icon name="check" size={16} class="mt-0.5 shrink-0 text-brand-blue-dark" />
                    <span>Free parking close to the building entrance</span>
                  </li>
                  <li class="inline-flex items-start gap-2">
                    <Icon name="check" size={16} class="mt-0.5 shrink-0 text-brand-blue-dark" />
                    <span>Elevator access · Suite 455 on the 4th floor</span>
                  </li>
                  <li class="inline-flex items-start gap-2">
                    <Icon name="check" size={16} class="mt-0.5 shrink-0 text-brand-blue-dark" />
                    <span>ADA-compliant building and exam rooms</span>
                  </li>
                </ul>
                <a
                  href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(CONTACT.address.full)}`}
                  target="_blank"
                  rel="noopener"
                  class="mt-6 inline-flex items-center gap-1.5 font-semibold text-brand-blue-dark hover:text-brand-blue wipe-underline"
                >
                  Get directions
                  <Icon name="arrow-up-right" size={16} />
                </a>
              </div>
            </div>
          </div>
        </Reveal>

        <Reveal delay={100}>
          <div class="card-premium halo h-full">
            <div class="flex items-start gap-4">
              <span class="icon-tile shrink-0">
                <Icon name="clock" size={22} />
              </span>
              <div class="w-full">
                <h2 class="font-display text-h3 font-semibold text-ink-900">Office hours</h2>
                <ul class="mt-4 divide-y divide-ink-100 text-body">
                  {
                    CONTACT.hours.map((h) => (
                      <li class="flex items-center justify-between gap-3 py-2.5">
                        <span class="font-medium text-ink-700">{h.day}</span>
                        <span class={h.open && h.close ? 'font-semibold text-ink-900' : 'text-ink-300'}>
                          {h.open && h.close ? `${h.open} – ${h.close}` : 'Closed'}
                        </span>
                      </li>
                    ))
                  }
                </ul>
                <p class="mt-5 text-meta text-ink-500">
                  <Icon name="check-circle" size={14} class="-mt-0.5 inline text-emerald-600" /> Same-day appointments are often available — call early.
                </p>
              </div>
            </div>
          </div>
        </Reveal>
      </div>

      <!-- Phone + email row -->
      <div class="mt-6 grid gap-6 sm:grid-cols-2">
        <Reveal delay={200}>
          <a href={`tel:${CONTACT.phoneRaw}`} class="card-premium halo block h-full">
            <div class="flex items-start gap-4">
              <span class="icon-tile icon-tile-red shrink-0">
                <Icon name="phone" size={22} />
              </span>
              <div>
                <p class="text-eyebrow font-semibold uppercase tracking-[0.12em] text-brand-blue-dark">Phone</p>
                <p class="mt-1 font-display text-h3 font-semibold text-ink-900">{CONTACT.phone}</p>
                <p class="mt-2 text-meta text-ink-500">Call for same-day appointments and questions.</p>
              </div>
            </div>
          </a>
        </Reveal>
        <Reveal delay={300}>
          <a href={`mailto:${CONTACT.email}`} class="card-premium halo block h-full">
            <div class="flex items-start gap-4">
              <span class="icon-tile shrink-0">
                <Icon name="mail" size={22} />
              </span>
              <div>
                <p class="text-eyebrow font-semibold uppercase tracking-[0.12em] text-brand-blue-dark">Email</p>
                <p class="mt-1 break-all font-display text-h4 font-semibold text-ink-900">{CONTACT.email}</p>
                <p class="mt-2 text-meta text-ink-500">For general inquiries only — please don't include personal health information.</p>
              </div>
            </div>
          </a>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- ====================================================
       MAP
       ==================================================== -->
  <section class="section">
    <div class="container-x">
      <Reveal class="section-head mx-auto text-center">
        <span class="eyebrow-dot">Find Us</span>
        <h2 class="editorial mt-3 text-h2 balance">Right in the <em>heart of Sherman</em>.</h2>
        <p class="text-meta text-ink-500">
          Inside the 300 N Highland Ave medical building — Suite 455.
        </p>
      </Reveal>
      <Reveal delay={100}>
        <div class="mt-10 aspect-video w-full overflow-hidden rounded-2xl ring-1 ring-ink-100 shadow-[0_24px_56px_-24px_rgba(10,15,26,0.18)]">
          <iframe
            src={`https://www.google.com/maps?q=${encodeURIComponent(CONTACT.address.full)}&output=embed`}
            title="Highland Primary Care — 300 N Highland Ave Suite 455, Sherman TX 75092"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="h-full w-full"
            style="border:0;"
            allowfullscreen
          ></iframe>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- ====================================================
       BOOKING
       ==================================================== -->
  <section class="section bg-white">
    <div class="container-x">
      <Reveal>
        <SectionHeader
          eyebrow="Request an Appointment"
          title="Book your visit online"
          lede="Fill out the form below and our team will contact you shortly to confirm. Prefer to talk? Call (903) 871-5671."
          align="center"
        />
      </Reveal>
      <div class="mx-auto mt-14 max-w-[650px]">
        <Reveal>
          <BookingEmbed src={BOOKING.general} />
        </Reveal>
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
