---
// Legacy URL redirect: /medicalweightloss/ → /medical-weight-loss/
// GitHub Pages doesn't support server-side 301s, so we use a meta-refresh
// HTML page that also sets canonical and rel=canonical for SEO.
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0; url=/medical-weight-loss/" />
    <link rel="canonical" href="https://highlandprimarycare.net/medical-weight-loss/" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Redirecting…</title>
    <script>
      window.location.replace('/medical-weight-loss/');
    </script>
  </head>
  <body>
    <p>Redirecting to <a href="/medical-weight-loss/">/medical-weight-loss/</a>…</p>
  </body>
</html>
