---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTABanner from '../../components/CTABanner.astro';
import Icon from '../../components/Icon.astro';
import Reveal from '../../components/Reveal.astro';
import Marquee from '../../components/Marquee.astro';
import MagneticButton from '../../components/MagneticButton.astro';
import ScrollProgress from '../../components/ScrollProgress.astro';
import { ARTICLES } from '../../content/articles';
import { BOOKING, CONTACT, SITE } from '../../config';
import { breadcrumbSchema } from '../../schema';

const sorted = [...ARTICLES].sort((a, b) => b.date.localeCompare(a.date));

// Lightweight category inference for visual variety on cards
function articleCategory(slug: string): { label: string; icon: 'stethoscope' | 'users' | 'heart-pulse' | 'list-checks' } {
  if (slug.includes('choosing')) return { label: 'Choosing a Doctor', icon: 'users' };
  if (slug.includes('role')) return { label: 'Primary Care 101', icon: 'stethoscope' };
  return { label: 'Health Education', icon: 'heart-pulse' };
}

const topics = [
  'Preventive Care',
  'Weight Loss',
  'TRT',
  'Chronic Disease',
  'Mental Health',
  'Nutrition',
  "Men's Health",
  'Geriatrics',
];
---

<BaseLayout
  title="Health Articles & Patient Education | Highland Primary Care Sherman TX"
  description="Practical, evidence-based health articles from the board-certified physicians at Highland Primary Care in Sherman, TX."
  schemaJson={breadcrumbSchema([
    { name: 'Home', url: `${SITE.url}/` },
    { name: 'Health Articles', url: `${SITE.url}/health-articles/` },
  ])}
>
  <ScrollProgress />

  <!-- ====================================================
       HERO
       ==================================================== -->
  <section class="hero-frame relative isolate">
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <div class="absolute -top-32 -left-24 h-[28rem] w-[28rem] rounded-full bg-brand-blue/10 blur-3xl animate-drift"></div>
      <div class="absolute -bottom-40 right-[-6rem] h-[32rem] w-[32rem] rounded-full bg-brand-red/8 blur-3xl animate-drift" style="animation-delay: -8s"></div>
    </div>

    <div class="container-x relative py-16 lg:py-24">
      <div class="mx-auto max-w-3xl text-center">
        <span class="eyebrow-dot animate-fade-up">Health Articles</span>
        <h1 class="editorial mt-6 text-display text-ink-900 balance animate-fade-up animation-delay-100">
          Practical health <em>education</em><br />
          for our patients.
        </h1>
        <p class="mx-auto mt-7 max-w-2xl text-lead text-ink-500 pretty animate-fade-up animation-delay-300">
          Evidence-based, plain-language guidance from the board-certified physicians at Highland Primary Care — written for the patients we see every day in Sherman and across Texoma.
        </p>
      </div>
    </div>
  </section>

  <!-- ====================================================
       ARTICLES GRID
       ==================================================== -->
  <section class="section">
    <div class="container-x">
      <Reveal class="section-head mx-auto text-center">
        <span class="eyebrow-dot">Latest Articles</span>
        <h2 class="editorial mt-3 text-h1 balance">Read, learn, <em>then bring questions</em>.</h2>
        <p class="text-lead text-ink-500 pretty">
          The best appointments start with an informed patient. Browse our latest articles below.
        </p>
      </Reveal>

      <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          sorted.map((a, i) => {
            const cat = articleCategory(a.slug);
            return (
              <Reveal delay={((i % 3) * 100) as 0 | 100 | 200}>
                <article class="card-premium hover-lift group flex h-full flex-col">
                  <a href={`/health-articles/${a.slug}/`} class="absolute inset-0 z-10" aria-label={a.title}></a>

                  <div class="relative -mx-6 -mt-6 mb-6 aspect-[16/9] overflow-hidden rounded-t-xl bg-gradient-to-br from-brand-blue-soft via-paper-tinted to-brand-red-soft md:-mx-8 md:-mt-8">
                    {a.image ? (
                      <img
                        src={a.image}
                        alt={a.imageAlt}
                        width="640"
                        height="360"
                        loading="lazy"
                        decoding="async"
                        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    ) : (
                      <div class="absolute inset-0 flex items-center justify-center text-brand-blue-dark/40">
                        <Icon name={cat.icon} size={64} />
                      </div>
                    )}
                    <span class="absolute left-4 top-4 inline-flex items-center gap-1.5 rounded-full bg-white/90 px-2.5 py-1 text-[0.6875rem] font-semibold uppercase tracking-[0.08em] text-brand-blue-dark backdrop-blur">
                      <Icon name={cat.icon} size={12} />
                      {cat.label}
                    </span>
                  </div>

                  <p class="text-meta font-semibold uppercase tracking-[0.08em] text-ink-500">
                    {new Date(a.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · {a.readingMinutes} min read
                  </p>
                  <h3 class="mt-3 font-display text-h3 font-semibold leading-tight text-ink-900 group-hover:text-brand-red transition-colors">
                    {a.title}
                  </h3>
                  <p class="mt-3 line-clamp-3 flex-1 text-body text-ink-500">{a.description}</p>
                  <span class="relative z-20 mt-6 inline-flex w-fit items-center gap-1.5 font-semibold text-brand-blue-dark transition-colors group-hover:text-brand-blue">
                    Read article
                    <Icon name="arrow-right" size={18} class="transition-transform duration-200 group-hover:translate-x-1" />
                  </span>
                </article>
              </Reveal>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- ====================================================
       TOPICS MARQUEE
       ==================================================== -->
  <section class="section section-tinted">
    <div class="container-x">
      <Reveal class="section-head mx-auto text-center">
        <span class="eyebrow-dot">Topics We Cover</span>
        <h2 class="editorial mt-3 text-h2 balance">Real medicine, <em>plainly explained</em>.</h2>
        <p class="text-meta text-ink-500">
          More articles publishing soon. Have a topic you'd like us to cover? <a href={`mailto:${CONTACT.email}`} class="font-semibold text-brand-blue-dark wipe-underline">Tell us</a>.
        </p>
      </Reveal>
      <div class="mt-10">
        <Marquee speed="36s">
          {topics.map((t) => (
            <span class="inline-flex items-center gap-2 rounded-xl border border-ink-100 bg-paper-elevated px-5 py-3 text-meta font-semibold text-ink-700">
              <Icon name="heart-pulse" size={16} class="text-brand-red" />
              {t}
            </span>
          ))}
        </Marquee>
      </div>
    </div>
  </section>

  <!-- ====================================================
       Q&A INVITATION
       ==================================================== -->
  <section class="section">
    <div class="container-x">
      <div class="mx-auto max-w-4xl">
        <Reveal>
          <div class="card-premium halo overflow-hidden">
            <div class="grid items-center gap-8 md:grid-cols-[1fr_auto]">
              <div>
                <span class="eyebrow-dot">Have a question?</span>
                <h2 class="editorial mt-3 text-h2 balance text-ink-900">
                  An article can't replace a <em>real conversation</em>.
                </h2>
                <p class="mt-4 text-body text-ink-500 pretty">
                  If something here applies to your health — or you want guidance for your specific situation — schedule a visit. We accept most major insurance and are taking new patients.
                </p>
              </div>
              <div class="flex flex-col gap-3 sm:flex-row md:flex-col lg:flex-row">
                <MagneticButton href={BOOKING.bookNow} target="_blank" rel="noopener noreferrer" class="btn-primary group">
                  <Icon name="calendar" size={18} />
                  Book a visit
                  <Icon name="arrow-right" size={16} class="transition-transform duration-200 group-hover:translate-x-0.5" />
                </MagneticButton>
                <a href={`tel:${CONTACT.phoneRaw}`} class="btn-secondary">
                  <Icon name="phone" size={18} />
                  {CONTACT.phone}
                </a>
              </div>
            </div>
          </div>
        </Reveal>
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
