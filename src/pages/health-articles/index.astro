---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import CTABanner from '../../components/CTABanner.astro';
import Icon from '../../components/Icon.astro';
import { ARTICLES } from '../../content/articles';
import { localBusinessSchema, breadcrumbSchema } from '../../schema';

const sorted = [...ARTICLES].sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout
  title="Health Articles — Highland Primary Care Sherman TX"
  description="Health articles and patient education from Highland Primary Care in Sherman, TX. Practical guidance from board-certified physicians."
  schemaJson={[
    localBusinessSchema(),
    breadcrumbSchema([
      { name: 'Home', url: 'https://highlandprimarycare.net/' },
      { name: 'Health Articles', url: 'https://highlandprimarycare.net/health-articles/' },
    ]),
  ]}
>
  <section class="bg-paper">
    <div class="container-x py-16 lg:py-22">
      <SectionHeader
        as="h1"
        eyebrow="Patient Education"
        title="Health articles & insights"
        lede="Practical, evidence-based guidance from the board-certified physicians at Highland Primary Care."
      />
    </div>
  </section>

  <section class="pb-20">
    <div class="container-x">
      <div class="grid gap-6 md:grid-cols-2">
        {
          sorted.map((a) => (
            <article class="card card-hover group flex flex-col">
              <span class="eyebrow">
                {new Date(a.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · {a.readingMinutes} min read
              </span>
              <h2 class="mt-3 font-display text-h3 text-ink-900 group-hover:text-brand-red">
                <a href={`/health-articles/${a.slug}/`}>{a.title}</a>
              </h2>
              <p class="mt-3 flex-1 text-body text-ink-500">{a.description}</p>
              <a
                href={`/health-articles/${a.slug}/`}
                class="mt-6 inline-flex items-center gap-1.5 font-semibold text-brand-blue-dark hover:text-brand-blue"
              >
                Read article
                <Icon name="arrow-right" size={18} class="transition-transform group-hover:translate-x-0.5" />
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
